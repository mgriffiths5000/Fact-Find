<!doctype html>
<html lang="en-GB">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="robots" content="noindex,nofollow">
<title>Protection Fact Find</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<script src="config.js"></script>

<style>
  :root {
    --bg: #f6f3ee;
    --bg-card: #ffffff;
    --ink: #1c2229;
    --ink-soft: #4f5862;
    --ink-mute: #8b929b;
    --accent: #2f4f3c;            /* deep eucalyptus */
    --accent-soft: #e7ede5;
    --accent-ink: #213a2c;
    --line: #e6e1d8;
    --line-strong: #d4ccbe;
    --warn: #b94a3a;
    --warn-soft: #fbe9e5;
    --shadow-sm: 0 1px 2px rgba(28,34,41,.04), 0 1px 1px rgba(28,34,41,.03);
    --shadow-md: 0 4px 14px -4px rgba(28,34,41,.08), 0 2px 4px rgba(28,34,41,.04);
    --shadow-lg: 0 24px 60px -24px rgba(28,34,41,.18), 0 8px 24px -12px rgba(28,34,41,.10);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 16px;
    --serif: 'Fraunces', 'Times New Roman', serif;
    --sans: 'Inter', system-ui, -apple-system, 'Segoe UI', sans-serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: var(--sans);
    color: var(--ink);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-size: 16px;
    line-height: 1.5;
    min-height: 100vh;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(900px 500px at 85% -10%, rgba(47,79,60,0.05), transparent 60%),
      radial-gradient(700px 400px at -10% 110%, rgba(47,79,60,0.04), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ========== Top bar ========== */
  header.bar {
    position: sticky; top: 0; z-index: 5;
    background: rgba(246,243,238,0.92);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .bar-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 14px 24px 12px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
  }
  .brand { display: flex; align-items: baseline; gap: 10px; }
  .brand .lockup {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .brand .sep { color: var(--ink-mute); font-size: 13px; }
  .brand .sub { font-size: 13px; color: var(--ink-soft); }

  .progress {
    flex: 1; max-width: 240px; height: 3px;
    background: var(--line); border-radius: 99px; overflow: hidden;
  }
  .progress-bar {
    height: 100%; width: 0%;
    background: var(--accent);
    transition: width .35s cubic-bezier(.6,.0,.2,1);
  }
  .progress-label {
    font-size: 12px; color: var(--ink-mute); font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ========== Layout ========== */
  main {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 120px;
    z-index: 1;
  }
  .stage {
    min-height: 60vh;
    display: flex; flex-direction: column; justify-content: center;
  }
  .card {
    background: transparent;
  }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    color: var(--accent-ink);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 20px;
  }
  .eyebrow .dot {
    width: 5px; height: 5px; border-radius: 99px; background: var(--accent);
  }

  h1.q-title {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(28px, 4.4vw, 40px);
    line-height: 1.18;
    letter-spacing: -0.018em;
    margin: 0 0 14px;
    color: var(--ink);
  }
  .q-title em { font-style: italic; color: var(--accent-ink); font-weight: 400; }
  .q-desc {
    color: var(--ink-soft);
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 32px;
    max-width: 600px;
  }
  .q-desc a { color: var(--accent-ink); text-decoration: underline; text-underline-offset: 3px; }
  .q-required { color: var(--warn); margin-left: 4px; }

  /* ========== Inputs ========== */
  .field { margin: 8px 0 0; }

  .input,
  textarea.input,
  select.input {
    width: 100%;
    font-family: var(--sans);
    font-size: 17px;
    color: var(--ink);
    background: var(--bg-card);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    padding: 14px 16px;
    line-height: 1.45;
    transition: border-color .18s ease, box-shadow .18s ease, background .18s ease;
    box-shadow: var(--shadow-sm);
  }
  .input:focus, textarea.input:focus, select.input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(47,79,60,0.12);
  }
  textarea.input { min-height: 130px; resize: vertical; }
  select.input { appearance: none; -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8'><path fill='none' stroke='%234f5862' stroke-width='1.6' d='M1 1.5l5 5 5-5'/></svg>");
    background-repeat: no-repeat; background-position: right 16px center;
    padding-right: 42px;
  }

  /* Choice buttons */
  .choices { display: grid; gap: 10px; margin-top: 4px; }
  .choice {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 16px;
    background: var(--bg-card);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color .15s ease, background .15s ease, transform .08s ease;
    user-select: none;
    box-shadow: var(--shadow-sm);
  }
  .choice:hover { border-color: var(--accent); background: #fdfcf9; }
  .choice:active { transform: translateY(1px); }
  .choice .key {
    font-family: var(--serif);
    font-size: 13px;
    width: 26px; height: 26px;
    border: 1px solid var(--line-strong);
    border-radius: 5px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--ink-soft);
    flex-shrink: 0;
    background: #fff;
    font-weight: 500;
  }
  .choice .label { font-size: 16px; color: var(--ink); }
  .choice.selected {
    border-color: var(--accent);
    background: var(--accent-soft);
  }
  .choice.selected .key {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .choice input[type=checkbox], .choice input[type=radio] { display: none; }

  /* Yes/No two-up */
  .yesno { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 480px) { .yesno { grid-template-columns: 1fr; } }

  .helper {
    font-size: 13px;
    color: var(--ink-mute);
    margin-top: 12px;
  }
  .error-msg {
    color: var(--warn);
    background: var(--warn-soft);
    border: 1px solid #f0c6bd;
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    margin-top: 14px;
    display: none;
  }
  .error-msg.show { display: block; }

  /* Statement / section card */
  .info-card {
    border-left: 2px solid var(--accent);
    padding: 4px 0 4px 18px;
    color: var(--ink-soft);
    font-size: 16px;
    line-height: 1.65;
    margin-top: 12px;
  }

  /* Inline group — render multiple subfields in one screen */
  .subfields { display: grid; gap: 20px; margin-top: 8px; }
  .subfield-row { display: grid; gap: 8px; }
  .subfield-row .sub-label {
    font-size: 14px; font-weight: 500; color: var(--ink-soft);
    line-height: 1.4;
  }
  .input.error-input {
    border-color: var(--warn);
    box-shadow: 0 0 0 3px rgba(185,74,58,0.10);
  }

  /* ========== Footer / actions ========== */
  .actions {
    display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    margin-top: 36px;
  }
  button.btn {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 500;
    padding: 12px 22px;
    border-radius: 99px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: transform .08s ease, background .15s ease, border-color .15s ease, color .15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  button.btn:active { transform: translateY(1px); }
  button.btn.primary {
    background: var(--accent); color: #fff; border-color: var(--accent);
  }
  button.btn.primary:hover { background: var(--accent-ink); }
  button.btn.ghost {
    background: transparent; color: var(--ink-soft); border-color: transparent;
  }
  button.btn.ghost:hover { color: var(--ink); }
  button.btn[disabled] { opacity: 0.45; cursor: not-allowed; transform: none; }
  .kbd-hint {
    font-size: 12px;
    color: var(--ink-mute);
    margin-left: auto;
    font-variant-numeric: tabular-nums;
  }
  .kbd-hint kbd {
    font-family: var(--serif); font-weight: 500; font-size: 12px;
    background: #fff;
    border: 1px solid var(--line-strong);
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 6px;
    margin: 0 2px;
    color: var(--ink-soft);
  }

  /* Question transitions */
  .stage > * { animation: enter .42s cubic-bezier(.2,.7,.2,1) both; }
  @keyframes enter {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Splash */
  .splash {
    text-align: left;
    max-width: 600px;
  }
  .splash h1 {
    font-family: var(--serif);
    font-size: clamp(36px, 6vw, 56px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0 0 22px;
    color: var(--ink);
  }
  .splash h1 em { font-style: italic; }
  .splash p { color: var(--ink-soft); font-size: 17px; line-height: 1.65; margin: 0 0 12px; }
  .resume-banner {
    display: flex; align-items: center; gap: 12px;
    background: var(--accent-soft);
    border: 1px solid #cfdcd2;
    color: var(--accent-ink);
    padding: 14px 16px;
    border-radius: var(--radius-md);
    font-size: 14px;
    margin: 28px 0 0;
  }
  .resume-banner button { background: none; border: 1px solid var(--accent); color: var(--accent-ink); padding: 6px 12px; border-radius: 99px; font-size: 13px; cursor: pointer; font-family: var(--sans); }
  .resume-banner button:hover { background: var(--accent); color: #fff; }

  /* Review */
  .review-section {
    margin-top: 36px; padding-top: 24px; border-top: 1px solid var(--line);
  }
  .review-section:first-of-type { border-top: none; padding-top: 0; }
  .review-section h3 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 22px;
    margin: 0 0 16px;
    letter-spacing: -0.01em;
  }
  .review-row {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--line);
    font-size: 14px;
  }
  .review-row:last-child { border-bottom: none; }
  .review-q { color: var(--ink-soft); }
  .review-a { color: var(--ink); white-space: pre-wrap; word-break: break-word; }
  @media (max-width: 600px) { .review-row { grid-template-columns: 1fr; gap: 4px; } }

  /* End / loading */
  .center {
    text-align: center; max-width: 480px;
    margin: 60px auto 0;
  }
  .center h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 32px;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .center p { color: var(--ink-soft); margin: 0 0 22px; }
  .spinner {
    width: 28px; height: 28px;
    border: 2px solid var(--line);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 18px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<header class="bar">
  <div class="bar-inner">
    <div class="brand">
      <span class="lockup">Baker Hudson Health</span>
      <span class="sep">·</span>
      <span class="sub">Protection Fact Find</span>
    </div>
    <div class="progress" aria-hidden="true"><div class="progress-bar" id="progressBar"></div></div>
    <div class="progress-label" id="progressLabel">—</div>
  </div>
</header>

<main>
  <div class="stage" id="stage">
    <div class="center">
      <div class="spinner"></div>
      <p>Loading your fact find…</p>
    </div>
  </div>
</main>

<script>
/* =====================================================================
 * Protection Fact Find — single-page form runtime
 *
 * Loads the unified schema (schema.json), renders one question at a time,
 * evaluates the original Typeform logic rules, validates and persists
 * answers locally, and submits to a configurable webhook.
 *
 * Configure the webhook URL by setting window.SUBMIT_URL before this
 * script loads, e.g. via a separate <script> tag or a query string.
 * ===================================================================== */

(function () {
  'use strict';

  // -------------------- Config --------------------
  const STORAGE_KEY = 'bhh_factfind_v1';
  const SUBMIT_URL = (window.SUBMIT_URL || new URLSearchParams(location.search).get('submit_url') || '').trim();

  // -------------------- State --------------------
  let schema = null;
  let orderById = new Map();      // ref -> entry
  let positionById = new Map();   // ref -> integer position in `order`
  let logicBySource = new Map();  // source_ref -> rule
  let thankyouRefs = new Set();

  let answers = {};               // ref -> value (string | number | boolean | string[])
  let history = [];               // stack of refs for back-button
  let currentRef = null;          // ref of currently rendered entry
  let pendingValue = null;        // staged value before commit

  // -------------------- Boot --------------------
  document.addEventListener('keydown', onGlobalKey);
  loadSchema();

  async function loadSchema() {
    try {
      const r = await fetch('schema.json', { cache: 'no-store' });
      if (!r.ok) throw new Error('Failed to load schema.json (' + r.status + ')');
      schema = await r.json();
      indexSchema();
      restoreOrSplash();
    } catch (err) {
      stage().innerHTML = `<div class="center"><h2>Sorry — couldn't load the form</h2><p>${escapeHtml(err.message)}</p></div>`;
    }
  }

  function indexSchema() {
    schema.order.forEach((e, i) => {
      orderById.set(e.ref, e);
      positionById.set(e.ref, i);
    });
    schema.logic.forEach(rule => logicBySource.set(rule.source_ref, rule));
    (schema.thankyou_refs || []).forEach(r => thankyouRefs.add(r));
  }

  // -------------------- Persistence --------------------
  function saveState() {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        answers, history, currentRef, savedAt: Date.now(),
      }));
    } catch (_) { /* storage may be disabled */ }
  }
  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : null;
    } catch (_) { return null; }
  }
  function clearState() {
    try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
  }

  function restoreOrSplash() {
    const saved = loadState();
    if (saved && saved.currentRef && saved.savedAt && (Date.now() - saved.savedAt < 1000 * 60 * 60 * 24 * 14)) {
      renderSplash(saved);
    } else {
      renderSplash(null);
    }
  }

  // -------------------- Splash / start --------------------
  function renderSplash(saved) {
    const startable = schema.order.find(e => e.kind !== 'section' || true) || schema.order[0];
    const hours = saved ? Math.round((Date.now() - saved.savedAt) / 3600000) : 0;
    stage().innerHTML = `
      <div class="splash">
        <span class="eyebrow"><span class="dot"></span>Protection fact find</span>
        <h1>Let's get the questions <em>out of the way</em>.</h1>
        <p>This form gathers everything insurers need to assess an application for life cover, critical illness cover or income protection.</p>
        <p>Most clients take 30–60 minutes. Your progress saves automatically as you go, so you can stop and pick up later on the same device.</p>
        <p>Have your bank details and recent health information to hand if you can.</p>
        <div class="actions">
          <button class="btn primary" id="startBtn">Begin <span aria-hidden="true">→</span></button>
        </div>
        ${saved ? `
          <div class="resume-banner">
            <span>You started this form ${hours === 0 ? 'recently' : `${hours} hour${hours === 1 ? '' : 's'} ago`}. Resume from where you left off?</span>
            <button id="resumeBtn">Resume</button>
            <button id="restartBtn" style="border-color:var(--line-strong);color:var(--ink-soft)">Start over</button>
          </div>` : ''}
      </div>`;
    document.getElementById('startBtn').addEventListener('click', () => {
      answers = {}; history = []; clearState();
      goTo(schema.order[0].ref);
    });
    if (saved) {
      document.getElementById('resumeBtn').addEventListener('click', () => {
        answers = saved.answers || {};
        history = saved.history || [];
        goTo(saved.currentRef);
      });
      document.getElementById('restartBtn').addEventListener('click', () => {
        if (!confirm('Start the form over from the beginning? Your existing answers will be cleared.')) return;
        clearState();
        renderSplash(null);
      });
    }
    setProgress(0);
  }

  // -------------------- Navigation --------------------
  function goTo(ref) {
    if (ref == null) return finish();
    const entry = orderById.get(ref);
    if (!entry) return finish();   // unknown ref — terminate gracefully
    currentRef = ref;
    pendingValue = (entry.kind === 'field') ? cloneValue(answers[ref]) : null;
    saveState();
    renderEntry(entry);
    setProgress(positionById.get(ref) / Math.max(1, schema.order.length - 1) * 100);
  }

  function pushHistoryAndGo(targetRef) {
    if (currentRef) history.push(currentRef);
    goTo(targetRef);
  }

  function back() {
    const prev = history.pop();
    if (prev) goTo(prev);
  }

  function next() {
    const entry = orderById.get(currentRef);
    if (!entry) return;
    if (entry.kind === 'field') {
      const ok = validateAndStage(entry);
      if (!ok) return;
      answers[currentRef] = pendingValue;
    } else if (entry.kind === 'page') {
      const ok = validatePage(entry);
      if (!ok) return;
      // Subfield values are already committed to answers in wirePageInputs
    }
    saveState();
    const target = resolveJump(entry);
    if (target == null) return finish();
    pushHistoryAndGo(target);
  }

  // -------------------- Logic engine --------------------
  function resolveJump(entry) {
    const rule = logicBySource.get(entry.ref);
    if (rule) {
      for (const action of rule.actions) {
        if (evalCondition(action.condition)) {
          return resolveJumpTarget(action.target_ref, entry.part);
        }
      }
    }
    // No matching rule — fall through to the next entry in document order
    const pos = positionById.get(entry.ref);
    if (pos == null) return null;
    if (pos + 1 >= schema.order.length) return null;
    return schema.order[pos + 1].ref;
  }

  // The original Typeform was 7 separate forms linked by "thank-you" redirect
  // screens that pointed to the next form. Crucially, all 7 forms reuse the SAME
  // UUID (ffc7d141-...) for that redirect screen, so a logic rule "jump to <ref>"
  // means different things depending on which part it's sourced from. We use the
  // source field's part number to figure out where to actually go.
  function resolveJumpTarget(targetRef, sourcePart) {
    const isThankyouRef = thankyouRefs.has(targetRef) ||
                          targetRef === 'default_tys' ||
                          (typeof targetRef === 'string' && targetRef.startsWith('default_'));
    if (isThankyouRef) {
      // Advance to the first entry of any later part
      for (const e of schema.order) {
        if (e.part > sourcePart) return e.ref;
      }
      // No later part exists — we're at the end of Part 7, finish the form
      return null;
    }
    return targetRef;
  }

  function evalCondition(cond) {
    if (!cond || !cond.op) return false;
    const op = cond.op;
    if (op === 'always') return true;
    const vars = cond.vars || [];

    if (op === 'and' || op === 'or') {
      const subs = vars.map(v => v.type === 'op' ? evalCondition(v.value) : false);
      return op === 'and' ? subs.every(Boolean) : subs.some(Boolean);
    }

    // For binary ops: var[0] is field, var[1] is choice/constant
    const left = readVar(vars[0]);
    const right = readVar(vars[1]);

    if (op === 'is' || op === 'equal') {
      // For multi-select arrays: 'is' means "answer contains the value"
      if (Array.isArray(left)) return left.includes(right);
      // Boolean and string comparisons
      if (typeof right === 'boolean' || typeof left === 'boolean') {
        return Boolean(left) === Boolean(right);
      }
      // Numeric coercion if both look numeric
      if (looksNumeric(left) && looksNumeric(right)) return Number(left) === Number(right);
      return String(left) === String(right);
    }
    if (op === 'greater_than') return numeric(left) > numeric(right);
    if (op === 'lower_than') return numeric(left) < numeric(right);
    if (op === 'greater_equal_than') return numeric(left) >= numeric(right);
    if (op === 'lower_equal_than') return numeric(left) <= numeric(right);
    if (op === 'not_equal') return String(left) !== String(right);
    if (op === 'contains') return String(left ?? '').toLowerCase().includes(String(right ?? '').toLowerCase());
    if (op === 'begins_with') return String(left ?? '').toLowerCase().startsWith(String(right ?? '').toLowerCase());
    if (op === 'ends_with') return String(left ?? '').toLowerCase().endsWith(String(right ?? '').toLowerCase());
    return false;
  }

  function readVar(v) {
    if (!v) return null;
    if (v.type === 'field') return answers[v.value];
    if (v.type === 'choice') return v.value;
    if (v.type === 'constant') return v.value;
    return null;
  }
  function looksNumeric(v) { return v !== null && v !== undefined && v !== '' && !isNaN(Number(v)); }
  function numeric(v) { return Number(v); }

  // -------------------- Rendering --------------------
  function stage() { return document.getElementById('stage'); }

  function renderEntry(entry) {
    if (entry.kind === 'section' || entry.kind === 'composite_label') {
      renderSection(entry);
    } else if (entry.kind === 'display') {
      renderDisplay(entry);
    } else if (entry.kind === 'page') {
      renderPage(entry);
    } else if (entry.kind === 'field') {
      renderField(entry);
    } else {
      renderField(entry); // fallback
    }
  }

  function renderSection(entry) {
    const eyebrow = `Section · Part ${entry.part}`;
    stage().innerHTML = `
      <div class="card">
        <span class="eyebrow"><span class="dot"></span>${escapeHtml(eyebrow)}</span>
        <h1 class="q-title">${formatTitle(entry.title)}</h1>
        ${entry.description ? `<div class="info-card">${formatTitle(entry.description)}</div>` : ''}
        ${navActions(false, 'Continue')}
      </div>`;
    wireNav();
  }

  function renderDisplay(entry) {
    stage().innerHTML = `
      <div class="card">
        <span class="eyebrow"><span class="dot"></span>Note · Part ${entry.part}</span>
        <h1 class="q-title">${formatTitle(entry.title)}</h1>
        ${entry.description ? `<p class="q-desc">${formatTitle(entry.description)}</p>` : ''}
        ${navActions(false, 'Continue')}
      </div>`;
    wireNav();
  }

  function renderPage(entry) {
    // Multi-question page — multiple subfields rendered together on one screen.
    // Mirrors how Typeform rendered contact_info and inline_group containers.
    const subfields = entry.subfields || [];
    const subfieldHtml = subfields.map((sf, i) => renderSubfield(sf, i)).join('');

    stage().innerHTML = `
      <div class="card">
        <span class="eyebrow"><span class="dot"></span>Part ${entry.part}</span>
        <h1 class="q-title">${formatTitle(entry.title)}</h1>
        ${entry.description ? `<p class="q-desc">${formatTitle(entry.description)}</p>` : ''}
        <div class="subfields">${subfieldHtml}</div>
        <div class="error-msg" id="err"></div>
        ${navActions(true, 'Continue')}
      </div>`;

    wireNav();
    wirePageInputs(entry);
    const first = stage().querySelector('input, select, textarea');
    if (first) setTimeout(() => { try { first.focus({ preventScroll: false }); } catch {} }, 60);
  }

  function renderSubfield(sf, idx) {
    const inputId = 'sub_' + idx;
    const stored = answers[sf.ref];
    let inputHtml = '';

    if (sf.type === 'short_text' || sf.type === 'email' || sf.type === 'phone_number') {
      const inputType = sf.type === 'email' ? 'email' : sf.type === 'phone_number' ? 'tel' : 'text';
      const v = stored ?? '';
      inputHtml = `<input class="input" id="${inputId}" data-ref="${escapeAttr(sf.ref)}" data-type="${escapeAttr(sf.type)}" type="${inputType}" autocomplete="${autocompleteFor(sf)}" value="${escapeAttr(v)}" />`;
    } else if (sf.type === 'long_text') {
      const v = stored ?? '';
      inputHtml = `<textarea class="input" id="${inputId}" data-ref="${escapeAttr(sf.ref)}" data-type="${escapeAttr(sf.type)}" rows="3">${escapeHtml(v)}</textarea>`;
    } else if (sf.type === 'number') {
      const v = (stored === undefined || stored === null) ? '' : stored;
      inputHtml = `<input class="input" id="${inputId}" data-ref="${escapeAttr(sf.ref)}" data-type="${escapeAttr(sf.type)}" type="number" inputmode="decimal" value="${escapeAttr(v)}" />`;
    } else {
      // Fallback — should be rare since contact_info/inline_group only contain text/number/email/phone
      const v = stored ?? '';
      inputHtml = `<input class="input" id="${inputId}" data-ref="${escapeAttr(sf.ref)}" data-type="${escapeAttr(sf.type || '')}" type="text" value="${escapeAttr(v)}" />`;
    }

    return `
      <div class="subfield-row">
        <label class="sub-label" for="${inputId}">${formatTitle(sf.title)}${sf.required ? '<span class="q-required">*</span>' : ''}</label>
        ${inputHtml}
      </div>`;
  }

  function wirePageInputs(entry) {
    // Commit each subfield's value directly to answers as the user types,
    // so progress is preserved if they navigate back/forward.
    stage().querySelectorAll('[data-ref]').forEach(el => {
      el.addEventListener('input', () => {
        const ref = el.dataset.ref;
        const type = el.dataset.type;
        let v = el.value;
        if (type === 'number') v = (v === '' ? '' : Number(v));
        answers[ref] = v;
        el.classList.remove('error-input');
      });
    });
  }

  function validatePage(entry) {
    const errEl = document.getElementById('err');
    if (errEl) errEl.classList.remove('show');

    const missing = [];
    let firstInvalid = null;

    for (const sf of (entry.subfields || [])) {
      const el = stage().querySelector(`[data-ref="${sf.ref}"]`);
      if (el) el.classList.remove('error-input');
      const v = answers[sf.ref];
      const empty = v === undefined || v === null || v === '' || (Array.isArray(v) && v.length === 0);

      if (sf.required && empty) {
        missing.push(stripFormatting(sf.title));
        if (el) el.classList.add('error-input');
        if (!firstInvalid) firstInvalid = el;
        continue;
      }
      if (!empty && sf.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) {
        missing.push(stripFormatting(sf.title) + ' (invalid email)');
        if (el) el.classList.add('error-input');
        if (!firstInvalid) firstInvalid = el;
      }
      if (!empty && sf.type === 'number' && isNaN(Number(v))) {
        missing.push(stripFormatting(sf.title) + ' (must be a number)');
        if (el) el.classList.add('error-input');
        if (!firstInvalid) firstInvalid = el;
      }
    }

    if (missing.length > 0) {
      if (errEl) {
        errEl.textContent = (missing.length === 1 ? 'Please complete: ' : 'Please complete these fields: ') + missing.join(', ');
        errEl.classList.add('show');
      }
      if (firstInvalid) firstInvalid.focus();
      return false;
    }
    return true;
  }

  function renderField(entry) {
    const ftype = entry.type;
    let inputHtml = '';

    if (ftype === 'short_text' || ftype === 'email' || ftype === 'phone_number') {
      const inputType = ftype === 'email' ? 'email' : ftype === 'phone_number' ? 'tel' : 'text';
      const v = pendingValue ?? '';
      inputHtml = `<input class="input" id="inp" type="${inputType}" autocomplete="${autocompleteFor(entry)}" value="${escapeAttr(v)}" />`;
    } else if (ftype === 'long_text') {
      const v = pendingValue ?? '';
      inputHtml = `<textarea class="input" id="inp" rows="5">${escapeHtml(v)}</textarea>`;
    } else if (ftype === 'number') {
      const v = (pendingValue === undefined || pendingValue === null) ? '' : pendingValue;
      inputHtml = `<input class="input" id="inp" type="number" inputmode="decimal" value="${escapeAttr(v)}" />`;
    } else if (ftype === 'date') {
      const v = pendingValue ?? '';
      inputHtml = `<input class="input" id="inp" type="date" value="${escapeAttr(v)}" />`;
    } else if (ftype === 'yes_no') {
      const sel = pendingValue;
      inputHtml = `
        <div class="choices yesno" id="choiceGroup" data-multi="false">
          <button type="button" class="choice ${sel === true ? 'selected' : ''}" data-val="true">
            <span class="key">Y</span><span class="label">Yes</span>
          </button>
          <button type="button" class="choice ${sel === false ? 'selected' : ''}" data-val="false">
            <span class="key">N</span><span class="label">No</span>
          </button>
        </div>`;
    } else if (ftype === 'multiple_choice') {
      const multi = !!entry.allow_multiple_selection;
      const sel = multi ? (Array.isArray(pendingValue) ? pendingValue : []) : pendingValue;
      const buttons = entry.choices.map((c, i) => {
        const active = multi ? sel.includes(c.ref) : sel === c.ref;
        const keyChar = i < 9 ? String(i + 1) : (i < 35 ? String.fromCharCode(65 + i - 9) : '·');
        return `<button type="button" class="choice ${active ? 'selected' : ''}" data-val="${escapeAttr(c.ref)}">
                  <span class="key">${keyChar}</span><span class="label">${formatTitle(c.label)}</span>
                </button>`;
      }).join('');
      const hint = multi
        ? '<div class="helper">Select all that apply. Press Enter or click Continue when finished.</div>'
        : '';
      inputHtml = `<div class="choices" id="choiceGroup" data-multi="${multi}">${buttons}</div>${hint}`;
    } else if (ftype === 'dropdown') {
      const v = pendingValue ?? '';
      const opts = ['<option value="">— Select —</option>']
        .concat(entry.choices.map(c => `<option value="${escapeAttr(c.ref)}" ${c.ref === v ? 'selected' : ''}>${escapeHtml(c.label)}</option>`))
        .join('');
      inputHtml = `<select class="input" id="inp">${opts}</select>`;
    } else {
      inputHtml = `<div class="info-card">[Unsupported field type: ${escapeHtml(ftype)}] — please contact your adviser.</div>`;
    }

    stage().innerHTML = `
      <div class="card">
        <span class="eyebrow"><span class="dot"></span>Part ${entry.part}</span>
        <h1 class="q-title">${formatTitle(entry.title)}${entry.required ? '<span class="q-required">*</span>' : ''}</h1>
        ${entry.description ? `<p class="q-desc">${formatTitle(entry.description)}</p>` : ''}
        <div class="field">${inputHtml}</div>
        <div class="error-msg" id="err"></div>
        ${navActions(true, 'Continue')}
      </div>`;

    wireNav();
    wireFieldInputs(entry);
    const inp = document.getElementById('inp');
    if (inp) setTimeout(() => { try { inp.focus({ preventScroll: false }); } catch {} }, 60);
  }

  function navActions(showBack, ctaText) {
    return `
      <div class="actions">
        <button class="btn primary" id="nextBtn">${escapeHtml(ctaText)} <span aria-hidden="true">→</span></button>
        ${history.length > 0 ? '<button class="btn ghost" id="backBtn">← Back</button>' : ''}
        <span class="kbd-hint">Press <kbd>Enter</kbd> to continue</span>
      </div>`;
  }

  function wireNav() {
    const nb = document.getElementById('nextBtn');
    if (nb) nb.addEventListener('click', next);
    const bb = document.getElementById('backBtn');
    if (bb) bb.addEventListener('click', back);
  }

  function wireFieldInputs(entry) {
    const inp = document.getElementById('inp');
    if (inp) {
      inp.addEventListener('input', () => {
        if (entry.type === 'number') pendingValue = inp.value === '' ? '' : Number(inp.value);
        else pendingValue = inp.value;
      });
      inp.addEventListener('change', () => {
        if (entry.type === 'dropdown') pendingValue = inp.value;
      });
    }
    const cg = document.getElementById('choiceGroup');
    if (cg) {
      const multi = cg.dataset.multi === 'true';
      cg.querySelectorAll('.choice').forEach(btn => {
        btn.addEventListener('click', () => {
          let raw = btn.dataset.val;
          let val = raw === 'true' ? true : raw === 'false' ? false : raw;
          if (multi) {
            if (!Array.isArray(pendingValue)) pendingValue = [];
            const idx = pendingValue.indexOf(val);
            if (idx === -1) pendingValue.push(val); else pendingValue.splice(idx, 1);
            btn.classList.toggle('selected');
          } else {
            cg.querySelectorAll('.choice').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
            pendingValue = val;
            // For Yes/No and single-choice, advance immediately for snappy UX
            if (entry.type === 'yes_no' || (entry.type === 'multiple_choice' && !multi)) {
              setTimeout(next, 180);
            }
          }
        });
      });
    }
  }

  function validateAndStage(entry) {
    const errEl = document.getElementById('err');
    function fail(msg) {
      if (errEl) { errEl.textContent = msg; errEl.classList.add('show'); }
      return false;
    }
    if (errEl) errEl.classList.remove('show');

    if (!entry.required) return true;
    const v = pendingValue;
    const empty = v === undefined || v === null || v === '' || (Array.isArray(v) && v.length === 0);
    if (empty) return fail('Please answer this question to continue.');
    if (entry.type === 'email' && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return fail('Please enter a valid email address.');
    if (entry.type === 'number' && isNaN(Number(v))) return fail('Please enter a number.');
    return true;
  }

  // -------------------- Finish / review --------------------
  function finish() {
    setProgress(100);
    const groups = buildReviewGroups();
    const sections = groups.map(g => `
      <div class="review-section">
        <h3>${escapeHtml(g.title)}</h3>
        ${g.rows.length === 0
          ? '<p style="color:var(--ink-mute);font-size:14px">No answers in this section.</p>'
          : g.rows.map(r => `
              <div class="review-row">
                <div class="review-q">${formatTitle(r.q)}</div>
                <div class="review-a">${formatAnswer(r.a)}</div>
              </div>`).join('')}
      </div>`).join('');

    stage().innerHTML = `
      <div class="card">
        <span class="eyebrow"><span class="dot"></span>Review &amp; submit</span>
        <h1 class="q-title">Almost <em>done</em>.</h1>
        <p class="q-desc">Please review the answers below. If anything needs changing, use the back button — your other answers will be kept.</p>
        ${sections}
        <div id="submitErr" class="error-msg"></div>
        <div class="actions" style="margin-top:32px">
          <button class="btn primary" id="submitBtn">Submit fact find <span aria-hidden="true">→</span></button>
          <button class="btn ghost" id="backBtn">← Back to last question</button>
        </div>
      </div>`;
    document.getElementById('backBtn').addEventListener('click', back);
    document.getElementById('submitBtn').addEventListener('click', onSubmit);
  }

  function buildReviewGroups() {
    const groups = [];
    let current = null;
    let lastPart = null;
    for (const entry of schema.order) {
      if (entry.kind === 'section') {
        current = { title: stripFormatting(resolveTemplates(entry.title)), rows: [] };
        groups.push(current);
        lastPart = entry.part;
      } else if (entry.kind === 'page') {
        // Multi-question page — render as its own section with each subfield as a row
        current = { title: stripFormatting(resolveTemplates(entry.title)), rows: [] };
        groups.push(current);
        lastPart = entry.part;
        for (const sf of (entry.subfields || [])) {
          const v = answers[sf.ref];
          if (v !== undefined && v !== null && v !== '') {
            current.rows.push({ q: stripFormatting(sf.title), a: v, ref: sf.ref, type: sf.type });
          }
        }
      } else if (entry.kind === 'field' && answers[entry.ref] !== undefined && answers[entry.ref] !== null && answers[entry.ref] !== '') {
        if (!current || lastPart !== entry.part) {
          current = { title: `Part ${entry.part}`, rows: [] };
          groups.push(current);
          lastPart = entry.part;
        }
        current.rows.push({ q: stripFormatting(entry.title), a: answers[entry.ref], ref: entry.ref, type: entry.type });
      }
    }
    // Drop empty groups
    return groups.filter(g => g.rows.length > 0);
  }

  function formatAnswer(a) {
    if (a === true) return 'Yes';
    if (a === false) return 'No';
    if (Array.isArray(a)) {
      return a.map(x => choiceLabel(x) ?? x).join(', ');
    }
    if (typeof a === 'string' && schema.choice_index && schema.choice_index[a]) {
      return escapeHtml(schema.choice_index[a].label);
    }
    return escapeHtml(String(a ?? ''));
  }
  function choiceLabel(ref) {
    const ci = schema.choice_index && schema.choice_index[ref];
    return ci ? escapeHtml(ci.label) : null;
  }

  async function onSubmit() {
    const errEl = document.getElementById('submitErr');
    const btn = document.getElementById('submitBtn');
    if (btn) { btn.disabled = true; btn.textContent = 'Submitting…'; }
    errEl.classList.remove('show');

    const payload = {
      schema_version: schema.meta.version,
      submitted_at: new Date().toISOString(),
      user_agent: navigator.userAgent,
      // Both raw answers AND a "rendered" view that's easier for downstream consumers
      answers: answers,
      rendered: renderForOutput(),
    };

    if (!SUBMIT_URL) {
      // No backend wired yet — show payload so the user can copy it
      stage().innerHTML = `
        <div class="card">
          <span class="eyebrow"><span class="dot"></span>Preview mode</span>
          <h1 class="q-title">Submission ready</h1>
          <p class="q-desc">No <code>SUBMIT_URL</code> is configured, so nothing was sent. Below is the JSON your backend will receive.</p>
          <pre style="background:#fff;border:1px solid var(--line-strong);border-radius:10px;padding:16px;overflow:auto;max-height:60vh;font-size:13px">${escapeHtml(JSON.stringify(payload, null, 2))}</pre>
        </div>`;
      return;
    }

    try {
      const r = await fetch(SUBMIT_URL, {
        method: 'POST',
        // text/plain avoids CORS preflight (Apps Script web apps don't handle OPTIONS).
        // The Apps Script handler reads e.postData.contents and JSON.parses it.
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(payload),
        redirect: 'follow',
      });
      if (!r.ok) throw new Error('Submit failed (' + r.status + ')');
      let result = null;
      try { result = await r.json(); } catch (_) {}
      if (result && result.ok === false) throw new Error(result.error || 'Submit refused');
      clearState();
      stage().innerHTML = `
        <div class="center">
          <h2>Thank you.</h2>
          <p>Your fact find has been received. Your adviser will be in touch shortly.</p>
        </div>`;
    } catch (err) {
      if (btn) { btn.disabled = false; btn.textContent = 'Submit fact find →'; }
      errEl.textContent = 'There was a problem submitting your answers. Please try again or contact your adviser. (' + err.message + ')';
      errEl.classList.add('show');
    }
  }

  function renderForOutput() {
    const groups = buildReviewGroups();
    return groups.map(g => ({
      section: g.title,
      items: g.rows.map(r => ({
        question: r.q,
        answer: renderAnswerText(r.a),
        ref: r.ref,
      })),
    }));
  }
  function renderAnswerText(a) {
    if (a === true) return 'Yes';
    if (a === false) return 'No';
    if (Array.isArray(a)) return a.map(x => (schema.choice_index[x]?.label) ?? x).join(', ');
    if (typeof a === 'string' && schema.choice_index[a]) return schema.choice_index[a].label;
    return String(a ?? '');
  }

  // -------------------- Helpers --------------------
  function setProgress(pct) {
    const p = Math.max(0, Math.min(100, pct));
    document.getElementById('progressBar').style.width = p + '%';
    document.getElementById('progressLabel').textContent = p > 0 && p < 100 ? Math.round(p) + '%' : (p === 100 ? 'Complete' : '');
  }

  function onGlobalKey(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      const tag = (e.target && e.target.tagName) || '';
      // Don't intercept Enter inside multi-line textareas
      if (tag === 'TEXTAREA') return;
      const nb = document.getElementById('nextBtn');
      if (nb && !nb.disabled) { e.preventDefault(); nb.click(); }
    }
  }

  function autocompleteFor(entry) {
    const k = (entry.subfield_key || '').toLowerCase();
    const map = { first_name: 'given-name', last_name: 'family-name', email: 'email', phone_number: 'tel' };
    return map[k] || 'on';
  }

  // Inline format: convert *foo* → italics, [text](url) → links, **foo** → bold (rare)
  function formatTitle(s) {
    if (!s) return '';
    let t = resolveTemplates(s);
    t = escapeHtml(t);
    t = t.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (m, txt, url) => `<a href="${url}" target="_blank" rel="noopener">${txt}</a>`);
    t = t.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    t = t.replace(/\*(.+?)\*/g, '<em>$1</em>');
    return t;
  }
  function stripFormatting(s) {
    if (!s) return '';
    return resolveTemplates(s).replace(/\*\*?(.+?)\*\*?/g, '$1').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1');
  }

  function resolveTemplates(s) {
    if (!s) return '';
    return s.replace(/\{\{hidden:([a-z_]+)\}\}/gi, (_, key) => {
      // Resolve the ones the original Typeform was passing forward via redirect URL
      if (key === 'name') {
        // Find the first_name subfield by subfield_key (now nested in a page)
        for (const e of schema.order) {
          if (e.kind === 'page') {
            for (const sf of (e.subfields || [])) {
              if (sf.subfield_key === 'first_name' && answers[sf.ref]) return String(answers[sf.ref]);
            }
          } else if (e.kind === 'field' && e.subfield_key === 'first_name' && answers[e.ref]) {
            return String(answers[e.ref]);
          }
        }
        return '';
      }
      if (key === 'email' || key === 'phone_number') {
        for (const e of schema.order) {
          if (e.kind === 'page') {
            for (const sf of (e.subfields || [])) {
              if (sf.subfield_key === key && answers[sf.ref]) return String(answers[sf.ref]);
            }
          } else if (e.kind === 'field' && e.subfield_key === key && answers[e.ref]) {
            return String(answers[e.ref]);
          }
        }
        return '';
      }
      return '';
    });
  }

  function escapeHtml(s) {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }
  function escapeAttr(s) { return escapeHtml(s); }
  function cloneValue(v) { return Array.isArray(v) ? v.slice() : v; }
})();
</script>
</body>
</html>
